# Server configuration
PORT=5000

# Database configuration
# Leave empty to use local JSON file database fallback (zero-config mode)
MONGODB_URI=mongodb://localhost:27017/booktoblog

# AI Provider configuration
# Add your Gemini key (recommended) and/or OpenAI key.
# If both are omitted, the app will run in "Mock AI Mode" for demonstrations.
GEMINI_API_KEY=
OPENAI_API_KEY=
